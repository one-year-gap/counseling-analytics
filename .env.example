# Runtime
APP_ENV=local
APP_NAME=recommendation-server
APP_PORT=8000
LOG_LEVEL=INFO

# Database (Java 레포와 동일 DB)
# 로컬(uvicorn 직접 실행): localhost 사용
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/holliverse
# Docker로 띄울 때만: localhost → host.docker.internal 로 바꿔서 호스트 Postgres 접속
# RDS 예시 (호스트/DB명/유저/비밀번호만 교체)
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@your-instance.xxxxx.ap-northeast-2.rds.amazonaws.com:5432/DBNAME
# RDS 연결 시 SSL 필요하면 true (기본 false)
DATABASE_SSL=false

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Recommendation
RECOMMEND_TOP_K=3
CACHE_TTL_DAYS=7
